---
import YorkshireRose from './YorkshireRose.astro';

const year = new Date().getFullYear();
---

<footer class="page-footer flex-shrink-0 w-full max-w-screen-xl mx-auto">
  <div class="flex flex-row justify-center flex-wrap mb-20 px-5 lg:px-10">
    <section class="stats grid grid-cols-2 md:grid-cols-4 gap-2.5 md:gap-y-0.5 md:gap-x-5 w-full mb-20">
      <img src="/img/stat-1.svg" alt="10 social rides a week" class="order-1" width="285" height="104" />
      <img src="/img/stat-2.svg" alt="200+ members" class="order-2" width="285" height="104" />
      <img src="/img/stat-3.svg" alt="2 overseas trips" class="order-3 md:order-4 lg:order-3" width="285" height="104" />
      <img src="/img/stat-4.svg" alt="6 British Cycling coaches" class="order-4 md:order-3 lg:order-4" width="285" height="104" />
    </section>
    <section class="copyright">
      <p class="w-full text-sm text-center">&copy; {year} Sitwell Cycling Club and its members. Sitwell Cycling Club is a British Cycling Affiliated Go-Ride Club, and is affiliated to Cycling Time Trials.</p>
      <p class="w-full text-sm text-center mb-10">Forged in Yorkshire<YorkshireRose class="inline-block align-middle w-4 h-4 mx-1 -translate-y-px" /> by <a href="https://www.colouringcode.com">Colouring Code</a> using <a href="https://astro.build/">Astro</a>, <a href="https://vercel.com/">Vercel</a> &amp; <a href="https://claude.com/claude-code">Claude</a>. Sitwell CC Crest expertly crafted by <a href="https://stvsmth.co.uk/">Steve Smith</a>.</p>
    </section>
    <section class="logos flex flex-row flex-wrap w-full">
      <div class="flex flex-row justify-center w-full lg:w-2/5 mb-10 lg:mb-0 lg:justify-end">
        <a href="https://www.britishcycling.org.uk/club/profile/7596/sitwell-cycling-club" class="mr-10 self-center p-0 hover:border-none focus:border-none">
          <picture>
            <source srcset="/img/bc-affiliated.webp 1x, /img/bc-affiliated@2x.webp 2x" type="image/webp" />
            <img src="/img/bc-affiliated.png" alt="British Cycling Affilated Club" width="98" height="55" />
          </picture>
        </a>
        <a href="https://www.britishcycling.org.uk/go-ride/article/goridest-What-is-Go-Ride" class="self-center p-0 hover:border-none focus:border-none">
          <picture>
            <source srcset="/img/bc-goride.webp 1x, /img/bc-goride@2x.webp 2x" type="image/webp" />
            <img src="/img/bc-goride.png" alt="British Cycling Go-Ride Registered Club" width="98" height="55" />
          </picture>
        </a>
      </div>
      <div class="flex flex-row justify-center w-full lg:w-1/5 mb-10 lg:mb-0">
        <img src="/img/scc-crest.svg" alt="Sitwell Cycling Club" width="105" height="119" />
      </div>
      <div class="flex flex-row justify-center w-full lg:w-2/5 lg:justify-start">
        <img src="/img/scc-stripes.svg" alt="#ShowUsYourStripes" width="216" height="119" />
      </div>
    </section>
  </div>
</footer>
