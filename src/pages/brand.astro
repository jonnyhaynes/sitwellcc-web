---
import Layout from '../layouts/Layout.astro';

// Brand guidelines. Uses the site's shared Layout so the header, footer and
// green/yellow banner match every other page. Content sections use the site's
// Tailwind utilities and font-ropa / font-ropa-bold classes.

const logos = [
  { file: 'scc-logotype.svg', bg: 'bg-white border border-black/10', label: 'Logotype', note: 'Primary wordmark, black on light' },
  { file: 'scc-logotype--white.svg', bg: 'bg-black', label: 'Reversed', note: 'White wordmark on dark / photo' },
  { file: 'scc-stripes.svg', bg: 'bg-black/5', label: 'Stripes lock-up', note: 'Wordmark with signature stripes' },
];

const primary = [
  { name: 'Club Green', hex: '#109A49', text: 'text-white', extra: 'RGB 16 154 73 · CMYK 90 15 90 3 · Pantone 355 C' },
  { name: 'Club Yellow', hex: '#FBDF08', text: 'text-black', extra: 'RGB 251 223 8 · CMYK 3 9 96 0 · Pantone 108 C' },
];
const extended = [
  { name: 'Amber', hex: '#EF9014' },
  { name: 'Red', hex: '#D61E1E' },
  { name: 'Brown', hex: '#A15433' },
  { name: 'Blue', hex: '#1D5EE3' },
];
const neutrals = [
  { name: 'Black', hex: '#000000' },
  { name: 'White', hex: '#FFFFFF', border: true },
];

const moodShots = [
  { img: '/img/rides.webp', label: 'Golden-hour road ride', wide: true },
  { img: '/img/offroad-rides.webp', label: 'Off-road / gravel', wide: false },
  { img: '/img/coaching.webp', label: 'Go-Ride coaching, under-16s', wide: false },
  { img: '/img/hill-climb.webp', label: 'Race day, effort & grit', wide: false },
  { img: '/img/green-rides.webp', label: 'Café stop & smiles', wide: false },
  { img: '/img/charity.webp', label: 'Charity & community', wide: false },
  { img: '/img/racing.webp', label: 'Effort in the landscape', wide: true },
];

const principles = [
  { h: 'Candid, not posed', p: 'Catch the moment — mid-climb, mid-laugh, mid-café-stop. Movement and expression over stiff line-ups.' },
  { h: 'Everyone belongs', p: 'Show the full range of ages, abilities and bikes. New riders and kids matter as much as racers.' },
  { h: 'Place & season', p: 'Lean into local landscape and weather — Yorkshire lanes, big skies, honest British conditions.' },
  { h: 'Natural light & colour', p: 'Golden-hour warmth, true greens. Keep edits light; avoid heavy filters that fight the green & yellow.' },
];
---

<Layout
  title="Brand // Sitwell Cycling Club"
  description="Brand guidelines for Sitwell Cycling Club: logo, colours, typography and imagery. Download the logo and font files."
>
  <!-- ===== Banner / title ===== -->
  <section class="title w-full px-5 lg:px-10 mb-20">
    <h1 class="text-6xl font-ropa-bold mb-5">Brand guidelines</h1>
    <h2 class="text-3xl font-ropa mb-5">We&apos;re here for the smiles, not the miles.</h2>
    <p class="lg:w-3/4">These guidelines keep the Sitwell CC identity consistent wherever it appears — on kit, on the website, on social media, on event banners and in print. Please use the supplied <a href="#downloads">logo, colour and font files</a> rather than re-creating them. The brand should always feel warm, active and welcoming — never corporate or intimidating.</p>
  </section>

  <!-- ===== Logo ===== -->
  <section id="logo" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">The logo</h2>
    <p class="lg:w-3/4 mb-10">The crest is the heart of the brand — a green-and-yellow shield carrying the white rose of Yorkshire and a rampant lion, expertly crafted for the club by <a href="https://stvsmth.co.uk/">Steve Smith</a>.</p>

    <div class="flex justify-center items-center bg-black/5 p-10 lg:p-20 mb-5">
      <img src="/img/scc-crest.svg" alt="Sitwell Cycling Club crest" width="220" height="249" />
    </div>

    <div class="grid md:grid-cols-3 gap-5 mb-10">
      {logos.map((l) => (
        <div class="border border-black/10">
          <div class={`flex items-center justify-center h-40 p-8 ${l.bg}`}>
            <img src={`/img/${l.file}`} alt={l.label} class="max-h-full w-auto" />
          </div>
          <div class="p-4 border-t border-black/10">
            <h3 class="font-ropa text-xl">{l.label}</h3>
            <p class="text-sm">{l.note}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      <div class="p-5 bg-black/5">
        <h3 class="text-2xl font-ropa mb-2 text-green">Do</h3>
        <ul class="text-sm list-disc ml-5">
          <li class="mb-1">Use the master files supplied in Downloads (SVG for screen &amp; large print).</li>
          <li class="mb-1">Place the crest on white, black, or club green.</li>
          <li>Keep clear space around the crest equal to the height of the white rose.</li>
        </ul>
      </div>
      <div class="p-5 bg-black/5">
        <h3 class="text-2xl font-ropa mb-2 text-red">Don&apos;t</h3>
        <ul class="text-sm list-disc ml-5">
          <li class="mb-1">Recolour, stretch, rotate or add effects to the crest.</li>
          <li class="mb-1">Reproduce the crest smaller than 40px on screen.</li>
          <li>Rebuild the wordmark in a different font.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ===== Colour ===== -->
  <section id="colour" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">Colour</h2>
    <p class="lg:w-3/4 mb-10">Green and yellow come straight from the crest and carry across kit, web and print. Use green as the lead, yellow as the spark — roughly 60% neutral, 30% green, 10% yellow.</p>

    <div class="grid md:grid-cols-2 gap-5 mb-10">
      {primary.map((c) => (
        <div class="border border-black/10">
          <div class={`h-32 flex items-end p-4 font-ropa ${c.text}`} style={`background:${c.hex}`}>{c.name}</div>
          <div class="p-4 border-t border-black/10">
            <p class="font-ropa text-xl">{c.hex}</p>
            <p class="text-sm">{c.extra}</p>
          </div>
        </div>
      ))}
    </div>

    <h3 class="text-2xl font-ropa mb-1">Extended palette</h3>
    <p class="text-sm mb-5">Used sparingly to colour-code ride groups, categories and states — never as a primary brand colour.</p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-10">
      {extended.map((c) => (
        <div class="border border-black/10">
          <div class="h-20" style={`background:${c.hex}`}></div>
          <div class="p-3 border-t border-black/10">
            <p class="font-ropa">{c.name}</p>
            <p class="text-2xs">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>

    <h3 class="text-2xl font-ropa mb-5">Neutrals</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {neutrals.map((c) => (
        <div class="border border-black/10">
          <div class={`h-20 ${c.border ? 'border-b border-black/10' : ''}`} style={`background:${c.hex}`}></div>
          <div class="p-3 border-t border-black/10">
            <p class="font-ropa">{c.name}</p>
            <p class="text-2xs">{c.hex}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== Typography ===== -->
  <section id="type" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">Typography</h2>
    <p class="lg:w-3/4 mb-10"><strong>Ropa Sans Pro</strong> does anything that shouts — headlines, nav, buttons. <strong>Arial</strong> does everything that explains — body copy and UI.</p>

    <div class="border border-black/10 p-5 lg:p-8 mb-5">
      <p class="text-sm font-ropa uppercase tracking-widest mb-3">Display — Ropa Sans Pro ExtraBold (font-ropa-bold)</p>
      <p class="font-ropa-bold text-6xl leading-none">Smiles not miles</p>
    </div>
    <div class="border border-black/10 p-5 lg:p-8 mb-5">
      <p class="text-sm font-ropa uppercase tracking-widest mb-3">Subhead — Ropa Sans Pro Bold (font-ropa)</p>
      <p class="font-ropa text-4xl">Ten social rides a week</p>
    </div>
    <div class="border border-black/10 p-5 lg:p-8">
      <p class="text-sm font-ropa uppercase tracking-widest mb-3">Body — Arial (font-arial)</p>
      <p class="text-lg">Offering nine social rides a week, Go-Ride coaching sessions for under-16s, monthly socials and overseas trips. There&apos;s something for everyone — on road and off-road. Arial keeps body copy clean, familiar and readable at any size.</p>
    </div>
  </section>

  <!-- ===== Imagery ===== -->
  <section id="imagery" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">Imagery</h2>
    <p class="lg:w-3/4 mb-10">Sitwell photography is warm, candid and documentary — the club as it actually is, not stock-photo perfection.</p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-2.5 mb-10">
      {moodShots.map((m) => (
        <div
          class={`relative h-64 md:h-96 flex items-end p-3 text-white ${m.wide ? 'col-span-2' : ''}`}
          style={`background-image:linear-gradient(180deg,rgba(0,0,0,0) 35%,rgba(0,0,0,0.65)),url('${m.img}');background-size:cover;background-position:center`}
        >
          <span class="font-ropa text-sm relative z-10">{m.label}</span>
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {principles.map((p) => (
        <div>
          <h3 class="text-xl font-ropa text-green mb-1">{p.h}</h3>
          <p class="text-sm">{p.p}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== In use ===== -->
  <section id="in-use" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">In use</h2>
    <p class="lg:w-3/4 mb-10">From the jersey on the road to the button on the website — the identity applied consistently.</p>

    <div class="grid md:grid-cols-2 gap-5">
      <div class="border border-black/10">
        <div class="h-64 overflow-hidden bg-white">
          <img src="/brand/assets/photos/club-kit.webp" alt="Sitwell CC 10 Years club jersey by Bioracer" class="w-full h-full object-cover scale-125 origin-center" />
        </div>
        <div class="p-4 border-t border-black/10">
          <h3 class="font-ropa text-xl">Club kit</h3>
          <p class="text-sm">The &ldquo;10 Years&rdquo; jersey — green &amp; yellow stripes, crest on the chest (Bioracer)</p>
        </div>
      </div>
      <div class="border border-black/10">
        <div class="h-64 overflow-hidden">
          <img src="/brand/assets/photos/banner.webp" alt="Sitwell CC crest flag on a fence" class="w-full h-full object-cover" />
        </div>
        <div class="p-4 border-t border-black/10">
          <h3 class="font-ropa text-xl">Social &amp; banners</h3>
          <p class="text-sm">Club flag — crest and stripes on white</p>
        </div>
      </div>
      <div class="border border-black/10">
        <div class="flex flex-col items-center justify-center gap-3 bg-white h-64 p-8">
          <a href="/membership" class="btn btn--large">Join us today</a>
          <p class="text-sm">Green button, yellow offset shadow</p>
        </div>
        <div class="p-4 border-t border-black/10">
          <h3 class="font-ropa text-xl">Web buttons</h3>
          <p class="text-sm">Primary action = green + yellow shadow</p>
        </div>
      </div>
      <div class="border border-black/10">
        <div class="h-64 overflow-hidden">
          <img src="/brand/assets/photos/badges.webp" alt="Sitwell CC enamel crest badges" class="w-full h-full object-cover" />
        </div>
        <div class="p-4 border-t border-black/10">
          <h3 class="font-ropa text-xl">Crest as a badge</h3>
          <p class="text-sm">Enamel pin badges — the crest in the physical world</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Downloads ===== -->
  <section id="downloads" class="w-full px-5 lg:px-10 mb-20">
    <h2 class="text-4xl font-ropa-bold mb-5">Downloads</h2>
    <p class="lg:w-3/4 mb-10">Everything you need to represent Sitwell CC correctly. Prefer SVG wherever possible — it stays crisp at any size.</p>

    <div class="grid md:grid-cols-2 gap-5 mb-10">
      <div class="p-5 bg-black/5">
        <h3 class="text-2xl font-ropa mb-2">Logo pack</h3>
        <p class="text-sm mb-5">Crest, wordmark and stripes lock-up in every variant (black, white, green), as SVG and high-res PNG.</p>
        <a class="btn" href="/brand/assets/downloads/sitwell-cc-logos.zip" download>Download logos (.zip)</a>
      </div>
      <div class="p-5 bg-black/5">
        <h3 class="text-2xl font-ropa mb-2">Font pack</h3>
        <p class="text-sm mb-5">Self-hosted Ropa Sans Pro webfonts — Bold and ExtraBold — in .woff2 and .woff.</p>
        <a class="btn" href="/brand/assets/downloads/sitwell-cc-fonts.zip" download>Download fonts (.zip)</a>
      </div>
    </div>

    <h3 class="text-2xl font-ropa mb-5">Individual files</h3>
    <p class="text-sm mb-5">SVG for screen &amp; large print; PNG for tools that don&apos;t take vectors.</p>
    <div class="grid md:grid-cols-3 gap-5">
      <div>
        <p class="font-ropa mb-2">Crest</p>
        <div class="flex flex-row flex-wrap gap-2.5">
          <a class="btn" href="/img/scc-crest.svg" download>SVG</a>
          <a class="btn" href="/brand/assets/logos/scc-crest.png" download>PNG</a>
        </div>
      </div>
      <div>
        <p class="font-ropa mb-2">Logotype</p>
        <div class="flex flex-row flex-wrap gap-2.5">
          <a class="btn" href="/img/scc-logotype.svg" download>SVG</a>
          <a class="btn" href="/brand/assets/logos/scc-logotype.png" download>PNG</a>
        </div>
      </div>
      <div>
        <p class="font-ropa mb-2">Stripes</p>
        <div class="flex flex-row flex-wrap gap-2.5">
          <a class="btn" href="/img/scc-stripes.svg" download>SVG</a>
          <a class="btn" href="/brand/assets/logos/scc-stripes.png" download>PNG</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
