---
import Layout from '../layouts/Layout.astro';
import groq from 'groq';
import { client } from '../lib/sanity';

type NewsItem = {
  _id: string;
  title?: string;
  slug?: { current: string };
  summary?: string;
};

const announcement = await client.fetch<NewsItem>(
  groq`*[_type == "post" && publishedAt <= now() && announcement == true] | order(publishedAt desc) [0]`,
);
const news = await client.fetch<NewsItem[]>(
  groq`*[_type == "post" && publishedAt <= now() && announcement != true] | order(publishedAt desc) [0...3]`,
);

// Crop a summary to its first sentence (up to and including the first full stop).
const firstSentence = (text = '') => {
  const end = text.indexOf('.');
  return end === -1 ? text : text.slice(0, end + 1);
};
---

<Layout
  title="Sitwell Cycling Club"
  description="Founded 2016. Rotherham Advertiser Sports Awards Club of the Year 2018. 10 social rides a week. Go-Ride Coaching. Meet Brookside Pharmacy, Whiston."
>
  <section class="updates grid gap-5 lg:grid-cols-4 px-5 lg:px-10 mb-20">
    <section class="announcements">
      <h3 class="w-full border-b-8 border-green mb-5 lg:mr-10"><span class="inline-block bg-green text-yellow text-md font-ropa uppercase pt-2 px-3">Announcements</span></h3>
      {announcement?.slug && (
        <article>
          <h2 class="text-3xl font-ropa-bold"><a href={`/news/${announcement.slug.current}`} class="text-black">{announcement.title}</a></h2>
          <p class="opacity-75">{firstSentence(announcement.summary)}</p>
        </article>
      )}
    </section>
    <section class="news lg:col-span-3">
      <h3 class="w-full border-b-8 border-yellow mb-5"><span class="inline-block bg-yellow text-green text-md font-ropa uppercase pt-2 px-3">Don&apos;t miss this</span></h3>
      <div class="grid gap-5 md:grid-cols-3">
        {news?.map((item) => item.slug && (
          <article>
            <h2 class="text-3xl font-ropa-bold"><a href={`/news/${item.slug.current}`} class="text-black">{item.title}</a></h2>
            <p class="opacity-75">{firstSentence(item.summary)}</p>
          </article>
        ))}
      </div>
    </section>
  </section>

  <section class="media flex flex-row w-full flex-wrap px-5 lg:px-10 mb-10">
    <article class="club-rides block relative w-full lg:w-7/12 lg:pr-5 mb-10 h-96">
      <a href="/rides" class="block w-full h-full overflow-hidden relative">
        <img src="/img/rides.webp" class="absolute inset-0 object-cover object-right w-full h-full" alt="A landscape photograph of a sunset over Whiston with two Club riders up front" />
        <div class="absolute left-0 bottom-0 text-white p-5">
          <h3 class="font-ropa text-lg uppercase">Club rides</h3>
          <h2 class="font-ropa text-3xl">We&apos;re here for the smiles, not&nbsp;the&nbsp;miles.</h2>
          <p>Ten social rides a week on Wednesday evenings, and Saturday and Sunday mornings.</p>
        </div>
        <button class="btn absolute top-5 left-5" aria-label="Find out more">Find out more</button>
      </a>
    </article>
    <article class="charity block relative w-full lg:w-5/12 lg:pl-5 mb-10 h-96">
      <a href="/charity" class="block w-full h-full overflow-hidden relative">
        <img src="/img/charity.webp" class="absolute inset-0 object-cover object-right w-full h-full" alt="A landscape photograph of Club members at Rotherham Hospice" />
        <div class="absolute bottom-0 left-0 text-white p-5">
          <h3 class="font-ropa text-lg uppercase">Charity work</h3>
          <h2 class="font-ropa text-3xl">We raise vital funds for&nbsp;local&nbsp;charities</h2>
          <p>In 2019 we raised over £12,250 for Rotherham Hospice through a range of activities.</p>
        </div>
        <button class="btn absolute top-5 right-5" aria-label="Find out more">Find out more</button>
      </a>
    </article>
    <article class="races block relative w-full lg:w-5/12 lg:pr-5 mb-10 h-96">
      <a href="/races" class="block w-full h-full overflow-hidden relative">
        <img src="/img/racing.webp" class="absolute inset-0 object-cover object-right w-full h-full" alt="A photograph of Club member Joe Srike racing up Ulley Lane" />
        <div class="absolute top-0 right-0 text-white text-right p-5 flex flex-col items-end">
          <h3 class="font-ropa text-lg uppercase">Races</h3>
          <h2 class="font-ropa text-3xl">
            We host races.<br />
            We support races.<br />
            We race.
          </h2>
          <p class="w-3/5 lg:w-2/5 mb-2.5 self-end">Up hills, down hills, round tracks, circuits, and off road.</p>
          <img src="/img/epic-kitemark--white.webp" alt="Equality and Parity In Cycling" width="40" height="55" />
        </div>
        <button class="btn absolute right-5 bottom-5" aria-label="Find out more">Find out more</button>
      </a>
    </article>
    <article class="coaching block relative w-full lg:w-7/12 lg:pl-5 mb-10 h-96">
      <a href="/coaching" class="block w-full h-full overflow-hidden relative">
        <img src="/img/coaching.webp" class="absolute inset-0 object-cover w-full h-full" alt="A photograph of our Go-Ride coaching group listneing to intructions from a mix of club coaches" />
        <div class="absolute bottom-0 left-0 text-white p-5">
          <h3 class="font-ropa text-lg uppercase">Go-ride coaching</h3>
          <h2 class="font-ropa text-3xl">We&apos;re coaching the&nbsp;next&nbsp;generation.</h2>
          <p>Our Saturday morning sessions are suitable for under 16s.</p>
        </div>
        <button class="btn absolute right-5 bottom-5" aria-label="Find out more">Find out more</button>
      </a>
    </article>
  </section>
</Layout>
