---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import { getPage } from '../lib/sanity';

const items = [
  { src: '/video/jersey.mp4', label: 'S/S Jersey' },
  { src: '/video/bib-shorts.mp4', label: 'Bib Shorts' },
  { src: '/video/cap.mp4', label: 'Cap' },
  { src: '/video/socks.mp4', label: 'Socks' },
];

const page = await getPage('kit');
---

<Layout
  title={page?.seo?.metaTitle ?? 'Kit // Sitwell Cycling Club'}
  description={page?.seo?.metaDescription ?? 'SCC + Bioracer = ♥'}
>
  <PageHeader page={page} title="Kit" subtitle="SCC + Bioracer = ♥">
    <p class="lg:w-3/4">With a great range of items including casual wear and at a very competitive price point, <a href="https://shop-bioracer.co.uk/">Bioracer</a> have been the club&apos;s kit supplier since 2021. After all, if it&apos;s good enough for the Belgian, Dutch, German, Team DSM and <a href="https://www.ineosgrenadiers.com/article/ineos-grenadiers-and-castelli-part-ways-after-five-successful-seasons">Ineos Grenadiers</a> cycling teams as well as local team <a href="https://www.cyclingsheffield.com/bioracer/">Cycling Sheffield</a>, then it&apos;s good enough for us.</p>
  </PageHeader>
  <section class="races w-full px-5 lg:px-10 mb-20 grid lg:grid-cols-3 lg:gap-5">
    <section class="lg:col-start-3 mb-10 lg:mb-0">
      <section class="p-5 bg-black/5">
        <h3 class="text-2xl font-ropa">Ordering kit</h3>
        <p class="text-sm mb-2">Ordering is easy. <strong>We place an order once every quarter.</strong> Usually the first two weeks in Janaury, April, July and October with the kit arriving around 6-8 weeks later.</p>
        <p class="text-sm mb-5"><strong>Orders are placed through the Bioracer online portal available only to members.</strong></p>
        <a class="btn" href="https://www.bioracer.co.uk/en/mybioracer">Order kit</a>
      </section>
    </section>
    <section class="lg:col-span-2 lg:col-start-1 lg:row-start-1">
      {items.map((item) => (
        <div class="mb-5 border border-black/5 block relative">
          <video src={item.src} muted controls playsinline class="w-full block"></video>
          <h2 class="font-ropa text-3xl absolute top-5 left-5">{item.label}</h2>
          <a class="btn absolute bottom-5 right-5" href="https://www.bioracer.co.uk/en/mybioracer">Order kit</a>
        </div>
      ))}
    </section>
  </section>
</Layout>
